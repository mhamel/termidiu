{
  "name": "termidiu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "main": "out/main/index.js",
  "scripts": {
    "sync": "rulesync generate && node Scripts/sync-windsurf-skills.mjs && node Scripts/sync-codex-skills.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder && node -e \"const {rcedit}=require('rcedit');rcedit('dist/win-unpacked/TERMIDIU.exe',{'icon':'resources/icon.ico'}).then(()=>console.log('icon ok'))\"",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@xterm/addon-fit": "^0.11.0",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "node-pty": "^1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "rcedit": "^5.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
